ALTER TABLE public.trait OWNER TO jam;

--
-- Name: vp; Type: VIEW; Schema: public; Owner: jam
--

CREATE VIEW public.vp AS
 SELECT person.person_key,
    person.name_common,
    job.date_start,
    job.boss
   FROM public.person,
    public.job
  WHERE ((person.person_key = job.person_key) AND (person.person_key ~~* 'n_us_gov_vp%'::text) AND (NOT (person.person_key ~~* '%vp_parent%'::text)) AND (NOT (person.person_key ~~* '%vp_spouse%'::text)) AND (NOT (person.person_key ~~* '%vp_host%'::text)) AND (NOT (person.person_key ~~* '%vp_ancestor%'::text)));


ALTER TABLE public.vp OWNER TO jam;

