-- Name: project_id_seq; Type: SEQUENCE OWNED BY; Schema: zoidoffice; Owner: postgres
--

ALTER SEQUENCE zoidoffice.project_id_seq OWNED BY zoidoffice.__project.id;


--
-- Name: pw; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.pw AS
 SELECT __diary.id AS diaryid,
    __project.id AS projectid,
    __project.description,
    date_part('epoch'::text, __diary.dateentered) AS dateenteredepoch,
    __diary.dateentered,
    query.query
   FROM (zoidoffice.__diary
     JOIN zoidoffice.__project ON ((__diary.projectid = __project.id))),
    LATERAL regexp_split_to_table(__diary.notes, '
'::text) query(query)
  WHERE ((query.query ~ '^pw: '::text) AND (__diary.projectid = __project.id));


ALTER TABLE zoidoffice.pw OWNER TO jam;

