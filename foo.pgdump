-- Name: flag flag_pkey; Type: CONSTRAINT; Schema: article2; Owner: jam
--

ALTER TABLE ONLY article2.flag
    ADD CONSTRAINT flag_pkey PRIMARY KEY (state_key);


--
-- Name: person person_pkey; Type: CONSTRAINT; Schema: article2; Owner: jam
--

ALTER TABLE ONLY article2.person
    ADD CONSTRAINT person_pkey PRIMARY KEY (person_key);


