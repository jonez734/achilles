ALTER TABLE public.__video OWNER TO jam;

--
-- Name: video; Type: VIEW; Schema: public; Owner: jam
--

CREATE VIEW public.video AS
 SELECT v.url,
    v.title,
    v.createdbyid,
    v.datecreated,
    v.approvedbyid,
    v.dateapproved,
    v.updatedbyid,
    v.dateupdated,
    date_part('epoch'::text, v.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, v.dateapproved) AS dateapprovedepoch,
    date_part('epoch'::text, v.dateupdated) AS dateupdatedepoch
   FROM public.__video v;


ALTER TABLE public.video OWNER TO jam;

