--
-- Name: n_us_state_list; Type: VIEW; Schema: public; Owner: jam
--

CREATE VIEW public.n_us_state_list AS
 SELECT s.state_key,
    s.name,
    s.capital,
    s.statehood_date,
    s.statehood_order,
    s.area_total,
    s.area_land,
    s.area_water,
    s.elevation_max,
    s.elevation_min,
    f.imagepath AS flagimagepath
   FROM public.__n_us_state_list s,
    public.flag f
  WHERE (s.state_key = f.state_key);


ALTER TABLE public.n_us_state_list OWNER TO jam;

