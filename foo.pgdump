--
-- Name: whiteboard; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.whiteboard AS
 SELECT wb.id,
    wb.tags,
    wb.projectids,
    wb.status,
    wb.datecreated,
    wb.createdbyid,
    wb.dateupdated,
    wb.updatedbyid,
    wb.entry,
    wb.dateclaimed,
    wb.claimedbyid,
    date_part('epoch'::text, wb.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, wb.dateupdated) AS dateupdatedepoch,
    createdby.moniker AS createdbymoniker,
    updatedby.moniker AS updatedbymoniker,
    claimedby.moniker AS claimedbymoniker
   FROM (((zoidoffice.__whiteboard wb
     LEFT JOIN engine.__member createdby ON ((createdby.id = wb.createdbyid)))
     LEFT JOIN engine.__member updatedby ON ((updatedby.id = wb.updatedbyid)))
     LEFT JOIN engine.__member claimedby ON ((claimedby.id = wb.claimedbyid)));


ALTER TABLE zoidoffice.whiteboard OWNER TO jam;

