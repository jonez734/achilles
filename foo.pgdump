--
-- Name: president; Type: VIEW; Schema: article2; Owner: jam
--

CREATE VIEW article2.president AS
 SELECT p.person_key,
    p.name_sur,
    p.name_common,
    p.gender,
    p.date_born,
    p.state_born,
    p.place_born,
    p.date_die,
    p.state_die,
    p.place_die,
    p.cause_die,
    p.date_bury,
    p.state_bury,
    p.place_bury,
    p.name_formal,
    p.title,
    p.name_heritage,
    p.honor,
    p.name_full,
    p.name_sur_born,
    p.name_given,
    p.name_given_born,
    p.name_heritage_born,
    p.name_full_born,
    p.name_full_pre,
    p.name_full_post,
    p.note,
    job.title AS jobtitle,
    job.date_start,
    job.boss,
    pic.path AS picpath,
    ( SELECT elector.party
           FROM article2.elector,
            article2.person
          WHERE (p.person_key = elector.person)
         LIMIT 1) AS party
   FROM article2.job,
    article2.person p,
    article2.pic
  WHERE ((job.person_key = p.person_key) AND (pic.person_key = job.person_key) AND (job.title ~~* 'n_us_gov_president%'::text));


