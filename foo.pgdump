--
-- Name: diary; Type: VIEW; Schema: public; Owner: jam
--

CREATE VIEW public.diary AS
 SELECT __diary.id,
    __diary.projectid,
    __diary.enteredbyid AS enteredby,
    __diary.dateentered,
    __diary.lastmodified,
    __diary.lastmodifiedbyid AS lastmodifiedby,
    __diary.notes,
    m1.moniker AS lastmodifiedbyname,
    m2.moniker AS postedbyname
   FROM ((zoidoffice.__diary
     LEFT JOIN engine.__member m1 ON ((m1.id = __diary.lastmodifiedbyid)))
     LEFT JOIN engine.__member m2 ON ((m2.id = __diary.enteredbyid)));


ALTER TABLE public.diary OWNER TO jam;

