-- Name: arap_id_seq; Type: SEQUENCE OWNED BY; Schema: zoidoffice; Owner: postgres
--

ALTER SEQUENCE zoidoffice.arap_id_seq OWNED BY zoidoffice.arap.id;


--
-- Name: customer; Type: VIEW; Schema: zoidoffice; Owner: postgres
--

CREATE VIEW zoidoffice.customer AS
 SELECT __customer.code,
    __customer.name,
    __customer.billingaddr1,
    __customer.billingaddr2,
    __customer.billingcity,
    __customer.billingstate,
    __customer.billingzip,
    __customer.billingphone,
    __customer.paypalemailaddress,
    __customer.invoiceemailaddress,
    __customer.pocemailaddress,
    __customer.datecreated,
    __customer.createdbyid,
    __customer.dateupdated,
    __customer.updatedbyid,
    __customer.baserate,
    __customer.hourlyrate,
    __customer.invoicedir,
    COALESCE(__customer.invoiceemailaddress, __customer.paypalemailaddress, __customer.pocemailaddress, NULL::text) AS emailaddress,
    date_part('epoch'::text, __customer.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, __customer.dateupdated) AS dateupdatedepoch
   FROM zoidoffice.__customer;


ALTER TABLE zoidoffice.customer OWNER TO postgres;

--
-- Name: diary; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.diary AS
 SELECT d.id,
    d.projectid,
    d.enteredbyid,
    d.dateentered,
    d.lastmodified,
    d.lastmodifiedbyid,
    d.notes,
    m1.moniker AS lastmodifiedbyname,
    m2.moniker AS enteredbyname,
    date_part('epoch'::text, d.lastmodified) AS lastmodifiedepoch,
    date_part('epoch'::text, d.dateentered) AS dateenteredepoch
   FROM ((zoidoffice.__diary d
     LEFT JOIN engine.__member m1 ON ((m1.id = d.lastmodifiedbyid)))
     LEFT JOIN engine.__member m2 ON ((m2.id = d.enteredbyid)));


ALTER TABLE zoidoffice.diary OWNER TO jam;

--
-- Name: diary_id_seq; Type: SEQUENCE; Schema: zoidoffice; Owner: postgres
--

CREATE SEQUENCE zoidoffice.diary_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;


ALTER TABLE zoidoffice.diary_id_seq OWNER TO postgres;

--
-- Name: diary_id_seq; Type: SEQUENCE OWNED BY; Schema: zoidoffice; Owner: postgres
--

ALTER SEQUENCE zoidoffice.diary_id_seq OWNED BY zoidoffice.__diary.id;


--
-- Name: map_task_project; Type: TABLE; Schema: zoidoffice; Owner: postgres
--

CREATE TABLE zoidoffice.map_task_project (
    projectid integer NOT NULL,
    taskid integer NOT NULL
);


ALTER TABLE zoidoffice.map_task_project OWNER TO postgres;

--
-- Name: note; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.note AS
 SELECT n.id,
    n.customercode,
    n.createdbyid,
    n.updatedbyid,
    n.datecreated,
    n.dateupdated,
    n.note,
    createdby.moniker AS createdbymoniker,
    updatedby.moniker AS updatedbymoniker
   FROM ((zoidoffice.__note n
     LEFT JOIN engine.__member createdby ON ((n.createdbyid = createdby.id)))
     LEFT JOIN engine.__member updatedby ON ((n.updatedbyid = updatedby.id)));


ALTER TABLE zoidoffice.note OWNER TO jam;

--
-- Name: payment; Type: VIEW; Schema: zoidoffice; Owner: postgres
--

CREATE VIEW zoidoffice.payment AS
 SELECT __payment.id,
    __payment.projectid,
    __payment.invoiceid,
    __payment.customercode,
    __payment.method,
    __payment.transactionid,
    __payment.grossamount,
    __payment.netamount,
    __payment.description,
    __payment.createdbyid,
    __payment.datecreated,
    __payment.modifiedbyid,
    __payment.datemodified,
    (__payment.grossamount - __payment.netamount) AS fee
   FROM zoidoffice.__payment;


ALTER TABLE zoidoffice.payment OWNER TO postgres;

--
-- Name: paymentevent; Type: VIEW; Schema: zoidoffice; Owner: postgres
--

CREATE VIEW zoidoffice.paymentevent AS
 SELECT __paymentevent.id,
    __paymentevent.paymentid,
    __paymentevent.status,
    __paymentevent.description,
    __paymentevent.datestamp,
    __paymentevent.createdbyid,
    __paymentevent.modifiedbyid,
    __paymentevent.datecreated,
    __paymentevent.datemodified
   FROM zoidoffice.__paymentevent;


ALTER TABLE zoidoffice.paymentevent OWNER TO postgres;

--
-- Name: pho; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.pho AS
 SELECT d.id AS diaryid,
    __project.id AS projectid,
    __project.description,
    date_part('epoch'::text, d.dateentered) AS dateenteredepoch,
    d.dateentered,
    query.query
   FROM (zoidoffice.__diary d
     LEFT JOIN zoidoffice.__project ON ((d.projectid = __project.id))),
    LATERAL regexp_split_to_table(d.notes, '
'::text) query(query)
  WHERE ((query.query ~ '^pho: '::text) AND (d.projectid = __project.id));


ALTER TABLE zoidoffice.pho OWNER TO jam;

--
-- Name: projectstatus; Type: TABLE; Schema: zoidoffice; Owner: postgres
--

CREATE TABLE zoidoffice.projectstatus (
    id integer NOT NULL,
    name text NOT NULL,
    description text NOT NULL
);


ALTER TABLE zoidoffice.projectstatus OWNER TO postgres;

--
-- Name: project; Type: VIEW; Schema: zoidoffice; Owner: jam
--

CREATE VIEW zoidoffice.project AS
 SELECT __project.id,
    __project.parentprojectid,
    __project.description,
    __project.statusid,
    __project.nextactiontime,
    __project.nextaction,
    __project.creationdate,
    __project.createdbyid,
    __project.lastmodified,
    __project.lastmodifiedbyid,
    __project.baserate,
    __project.hourlyrate,
    __project.code,
    __project.customercode,
    __project.statusname,
    __project.claimedbyid,
    __project.dateclaimed,
    date_part('epoch'::text, __project.nextactiontime) AS nextactiontimeepoch,
    date_part('epoch'::text, __project.creationdate) AS creationdateepoch,
    date_part('epoch'::text, __project.lastmodified) AS lastmodifiedepoch,
    date_part('epoch'::text, __project.dateclaimed) AS dateclaimedepoch,
    COALESCE(claimedby.moniker, ''::text) AS claimedbymoniker,
    (now() - __project.nextactiontime) AS moldytime
   FROM ((zoidoffice.__project
     LEFT JOIN zoidoffice.projectstatus ON ((projectstatus.id = __project.statusid)))
     LEFT JOIN engine.__member claimedby ON ((claimedby.id = __project.claimedbyid)));


ALTER TABLE zoidoffice.project OWNER TO jam;

--
-- Name: project_id_seq; Type: SEQUENCE; Schema: zoidoffice; Owner: postgres
--

CREATE SEQUENCE zoidoffice.project_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1;


ALTER TABLE zoidoffice.project_id_seq OWNER TO postgres;

