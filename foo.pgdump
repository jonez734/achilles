--
-- Name: node; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.node AS
 SELECT n.id,
    n.parentid,
    n.attributes,
    n.datecreated,
    n.createdbyid,
    n.dateupdated,
    n.updatedbyid,
    n.dateapproved,
    n.approvedbyid,
    date_part('epoch'::text, n.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, n.dateupdated) AS dateupdatedepoch,
    date_part('epoch'::text, n.dateapproved) AS dateapprovedepoch,
    COALESCE(m1.moniker, 'a. nonymous'::text) AS createdbyname,
    COALESCE(m2.moniker, 'a. nonymous'::text) AS updatedbyname,
    COALESCE(m3.moniker, 'a. nonymous'::text) AS approvedbyname,
    ARRAY( SELECT DISTINCT map.sigpath
           FROM engine.map_node_sig map
          WHERE (map.nodeid = n.id)
          ORDER BY map.sigpath) AS sigs,
    ( SELECT count(subnodes.id) AS count
           FROM ( SELECT subnode.id
                   FROM engine.__node subnode
                  WHERE (subnode.parentid = n.id)) subnodes) AS subnodecount
   FROM (((engine.__node n
     LEFT JOIN engine.__member m1 ON ((m1.id = n.createdbyid)))
     LEFT JOIN engine.__member m2 ON ((m2.id = n.updatedbyid)))
     LEFT JOIN engine.__member m3 ON ((m3.id = n.approvedbyid)));


ALTER TABLE engine.node OWNER TO jam;

--
-- Name: mantra; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.mantra AS
 SELECT node.id,
    node.parentid,
    node.attributes,
    node.datecreated,
    node.createdbyid,
    node.dateupdated,
    node.updatedbyid,
    node.dateapproved,
    node.approvedbyid,
    node.datecreatedepoch,
    node.dateupdatedepoch,
    node.dateapprovedepoch,
    node.createdbyname,
    node.updatedbyname,
    node.approvedbyname,
    node.sigs,
    node.subnodecount,
    (node.attributes ->> 'description'::text) AS description,
    (node.attributes ->> 'author'::text) AS author,
    (node.attributes ->> 'reference'::text) AS reference
   FROM engine.node;


ALTER TABLE engine.mantra OWNER TO jam;

