--
-- Name: president; Type: VIEW; Schema: public; Owner: jam
--

CREATE VIEW public.president AS
 SELECT person.person_key,
    person.name_common,
    ( SELECT elector.party
           FROM public.elector
          WHERE (person.person_key = elector.person)
         LIMIT 1) AS party
   FROM public.person
  WHERE ((person.person_key ~~* '%president%'::text) AND (NOT (person.person_key ~~* '%president_parent%'::text)) AND (NOT (person.person_key ~~* '%president_spouse%'::text)) AND (NOT (person.person_key ~~* '%president_host%'::text)) AND (NOT (person.person_key ~~* '%president_ancestor%'::text)));


ALTER TABLE public.president OWNER TO jam;

