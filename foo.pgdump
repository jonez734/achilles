    ADD CONSTRAINT attraction_join_pkey PRIMARY KEY (person_key, place_key);


--
-- Name: attraction_place attraction_place_place_key_key; Type: CONSTRAINT; Schema: article2; Owner: jam
--

ALTER TABLE ONLY article2.attraction_place
    ADD CONSTRAINT attraction_place_place_key_key UNIQUE (place_key);


--
-- Name: flag flag_path_key; Type: CONSTRAINT; Schema: article2; Owner: jam
--

ALTER TABLE ONLY article2.flag
    ADD CONSTRAINT flag_path_key UNIQUE (path);


