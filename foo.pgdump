CREATE VIEW article2.vp AS
 SELECT person.person_key,
    person.name_sur,
    person.name_common,
    person.gender,
    person.date_born,
    person.state_born,
    person.place_born,
    person.date_die,
    person.state_die,
    person.place_die,
    person.cause_die,
    person.date_bury,
    person.state_bury,
    person.place_bury,
    person.name_formal,
    person.title,
    person.name_heritage,
    person.honor,
    person.name_full,
    person.name_sur_born,
    person.name_given,
    person.name_given_born,
    person.name_heritage_born,
    person.name_full_born,
    person.name_full_pre,
    person.name_full_post,
    person.note,
    job.title AS jobtitle,
    job.date_start,
    job.boss,
    pic.path AS picpath,
    ( SELECT elector.party
           FROM article2.elector,
            article2.person person_1
          WHERE (person_1.person_key = elector.person)
         LIMIT 1) AS party
   FROM article2.job,
    article2.person,
    article2.pic
  WHERE ((job.person_key = person.person_key) AND (pic.person_key = job.person_key) AND (job.title ~~* 'n_us_gov_vp%'::text));


