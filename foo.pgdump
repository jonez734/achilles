--
-- Name: notify; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.notify AS
 SELECT n.id,
    n.memberid,
    n.sessionid,
    n.type,
    n.status,
    n.template,
    n.urgent,
    n.datecreated,
    n.createdbyid,
    n.dateupdated,
    n.updatedbyid,
    n.datedisplayed,
    n.data,
    date_part('epoch'::text, n.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, n.datedisplayed) AS datedisplayedepoch,
    date_part('epoch'::text, n.dateupdated) AS dateupdatedepoch
   FROM engine.__notify n;


ALTER TABLE engine.notify OWNER TO jam;

--
-- Name: member; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.member AS
 SELECT m.id,
    m.moniker,
    m.email,
    m.password,
    m.credits,
    m.datecreated,
    m.createdbyid,
    m.dateupdated,
    m.updatedbyid,
    m.approvedbyid,
    m.dateapproved,
    m.lastlogin,
    m.lastloginfrom,
    m.attributes,
    m.tz,
    m.loginid,
    ( SELECT count(notify1.id) AS count
           FROM engine.notify notify1
          WHERE (notify1.memberid = m.id)) AS notifycount,
    ( SELECT count(notify2.id) AS count
           FROM engine.notify notify2
          WHERE ((notify2.memberid = m.id) AND (notify2.status = 'sent'::text))) AS sentnotifycount,
    ( SELECT count(notify3.id) AS count
           FROM engine.notify notify3
          WHERE ((notify3.memberid = m.id) AND (notify3.status = 'delivered'::text))) AS sentdeliveredcount,
    ( SELECT count(notify4.id) AS count
           FROM engine.notify notify4
          WHERE ((notify4.memberid = m.id) AND (notify4.status = 'read'::text))) AS sentreadcount,
    date_part('epoch'::text, m.datecreated) AS datecreatedepoch,
    date_part('epoch'::text, m.lastlogin) AS lastloginepoch,
    date_part('epoch'::text, m.dateapproved) AS dateapprovedepoch,
    date_part('epoch'::text, m.dateupdated) AS dateupdatedepoch,
    timezone(m.tz, m.datecreated) AS datecreatedlocal,
    timezone(m.tz, m.lastlogin) AS lastloginlocal,
    timezone(m.tz, m.dateapproved) AS dateapprovedlocal,
    timezone(m.tz, m.dateupdated) AS dateupdatedlocal
   FROM engine.__member m;


ALTER TABLE engine.member OWNER TO jam;

--
-- Name: session; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.session AS
 SELECT s.id,
    s.expiry,
    s.lastactivity,
    s.data,
    s.ipaddress,
    s.useragent,
    s.datecreated,
    s.dateupdated,
    s.memberid,
    date_part('epoch'::text, s.expiry) AS expiryepoch,
    date_part('epoch'::text, s.lastactivity) AS lastactivityepoch
   FROM engine.__session s;


ALTER TABLE engine.session OWNER TO jam;

--
-- Name: sig; Type: VIEW; Schema: engine; Owner: jam
--

CREATE VIEW engine.sig AS
 SELECT s.id,
    s.intro,
    s.path,
    s.title,
    s.attributes,
    s.dateupdated,
    s.updatedbyid,
    s.datecreated,
    s.createdbyid,
    engine.buildsiguri(s.path) AS uri,
    COALESCE(m1.moniker, 'a. nonymous'::text) AS createdbyname,
    COALESCE(m2.moniker, 'a. nonymous'::text) AS updatedbyname
   FROM ((engine.__sig s
     LEFT JOIN engine.__member m1 ON ((m1.id = s.createdbyid)))
     LEFT JOIN engine.__member m2 ON ((m2.id = s.updatedbyid)));


ALTER TABLE engine.sig OWNER TO jam;

